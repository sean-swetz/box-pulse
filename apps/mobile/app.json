{
  "expo": {
    "name": "BoxPulse",
    "slug": "boxpulse",
    "owner": "mrswetz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "boxpulse",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#102216"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.boxpulse.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#102216"
      },
      "package": "com.boxpulse.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0df259"
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://boxpulseapi-production.up.railway.app/api",
      "eas": {
        "projectId": "12682576-77f0-4f75-86d6-f028908dd18c"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "newArchEnabled": true
  }
}
