{
  "expo": {
    "name": "BoxPulse",
    "slug": "boxpulse",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "boxpulse",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#102216"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.boxpulse.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#102216"
      },
      "package": "com.boxpulse.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0df259"
        }
      ]
    ],
    "extra": {
      "apiUrl": "http://192.168.1.45:3000/api"
    },
    "experiments": {
      "typedRoutes": true
    },
    "newArchEnabled": true
  }
}
